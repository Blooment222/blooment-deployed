# ==========================================
# BLOOMENT - VARIABLES DE ENTORNO
# ==========================================
# Copia este archivo a .env y completa con tus credenciales reales
# NO subas el archivo .env a Git (está en .gitignore)

# ==========================================
# BASE DE DATOS - SUPABASE POSTGRESQL
# ==========================================
# Obtén estas URLs en: Supabase Dashboard → Settings → Database → Connection string

# Connection Pooling (con pgbouncer) - Usa puerto 6543
DATABASE_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"

# Direct Connection - Usa puerto 5432
DIRECT_URL="postgresql://postgres.TU_PROJECT_REF:TU_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres"

# ==========================================
# APLICACIÓN
# ==========================================
# URL base de tu aplicación (cambiar en producción)
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# CORS Origins (en producción, especifica tu dominio)
CORS_ORIGINS="*"

# ==========================================
# AUTENTICACIÓN JWT
# ==========================================
# Genera un secreto fuerte y único para tu aplicación
# Ejemplo: openssl rand -base64 32
JWT_SECRET="CAMBIA_ESTO_POR_UN_SECRETO_SUPER_SEGURO"

# ==========================================
# GOOGLE OAUTH
# ==========================================
# Obtén estas credenciales en: https://console.cloud.google.com/
# 1. Crea un proyecto
# 2. APIs & Services → Credentials → Create Credentials → OAuth 2.0 Client ID
# 3. Authorized redirect URIs: https://tu-dominio.com/api/auth/google/callback

GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-client-secret"

# ==========================================
# RESEND (EMAILS)
# ==========================================
# Obtén tu API Key en: https://resend.com/api-keys
RESEND_API_KEY="re_..."
SENDER_EMAIL="hola@tu-dominio.com"

# ==========================================
# MAPBOX (AUTOCOMPLETADO DE DIRECCIONES)
# ==========================================
# Obtén tu token en: https://account.mapbox.com/access-tokens/
# Necesitas un token público (empieza con pk.)
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN="pk...."

# ==========================================
# ONESIGNAL (NOTIFICACIONES PUSH)
# ==========================================
# Obtén estas credenciales en: https://onesignal.com/
# 1. Crea una app
# 2. Settings → Keys & IDs

ONESIGNAL_APP_ID="tu-app-id-aqui"
ONESIGNAL_API_KEY="tu-api-key-aqui"

# ==========================================
# SERVICIOS DEPRECATED (NO USAR)
# ==========================================
# MongoDB - Ya no se usa (migrado a PostgreSQL)
MONGO_URL="mongodb://localhost:27017"
DB_NAME="deprecated"

# Gmail SMTP - Reemplazado por Resend
EMAIL_USER="deprecated"
EMAIL_PASS="deprecated"
