// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// Modelo Administrador (para autenticación)
model Administrador {
  id        String   @id @default(uuid())
  nombre    String
  email     String   @unique
  password  String   // Hash del password con bcrypt
  activo    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("administradores")
}

// Modelo Cliente (usuarios de la tienda)
model Cliente {
  id        String   @id @default(uuid())
  nombre    String
  email     String   @unique
  password  String   // Hash del password con bcrypt
  telefono  String?
  direccion String?
  activo    Boolean  @default(true)
  
  // Push Notifications
  push_token         String?   // OneSignal Player ID o Push Token
  push_enabled       Boolean   @default(false) // Si tiene notificaciones activadas
  push_subscribed_at DateTime? // Cuando se suscribió
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  pedidos           Pedido[]
  contactosFavoritos ContactoFavorito[]

  @@map("clientes")
}

// Modelo ContactoFavorito (libreta de direcciones del cliente)
model ContactoFavorito {
  id             String    @id @default(uuid())
  clienteId      String
  nombre         String
  telefono       String
  direccion      String
  fecha_especial DateTime?
  motivo         String?   // Cumpleaños, Aniversario, etc.
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  cliente Cliente @relation(fields: [clienteId], references: [id], onDelete: Cascade)

  @@index([clienteId])
  @@index([fecha_especial])
  @@map("contactos_favoritos")
}

// Modelo Usuario (clientes)
model Usuario {
  id        String   @id @default(uuid())
  nombre    String
  email     String   @unique
  telefono  String?
  direccion String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  pedidos Pedido[]
  pagos   Pago[]

  @@map("usuarios")
}

// Modelo Producto
model Producto {
  id          String   @id @default(uuid())
  nombre      String
  descripcion String?
  medidas     String?  // Ej: "40cm x 30cm"
  flores_incluidas String?  // Ej: "12 rosas rojas, 5 lirios blancos, follaje"
  precio      Float
  stock       Int      @default(0)
  imagen_url  String?
  
  // Campos de clasificación
  categoria           String?  // Ramos, Arreglos, Plantas, etc
  tipo_flor           String?  // Rosas, Tulipanes, Girasoles, etc
  ocasion             String?  // Boda, Cumpleaños, Aniversario, etc
  
  // Campos de ofertas
  en_oferta           Boolean  @default(false)
  precio_oferta       Float?
  porcentaje_descuento Int?
  fecha_inicio_oferta DateTime?
  fecha_fin_oferta    DateTime?
  
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relaciones
  detallesPedido DetallePedido[]

  @@map("productos")
}

// Modelo Pedido
model Pedido {
  id        String   @id @default(uuid())
  usuarioId String?
  clienteId String?
  total     Float
  estado    String   @default("pendiente") // pendiente, en_preparacion, enviado, entregado, cancelado
  fecha     DateTime @default(now())
  
  // Datos del cliente
  nombre_cliente      String
  email_cliente       String
  telefono_cliente    String?
  direccion_envio     String
  
  // Detalles de entrega y regalo
  nombre_destinatario String?
  tel_destinatario    String?
  horario_entrega     String?  // "10:00-13:00", "13:00-15:00", "15:00-18:00"
  dedicatoria         String?  @db.Text
  
  // Stripe
  stripe_session_id   String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  usuario        Usuario?        @relation(fields: [usuarioId], references: [id], onDelete: Cascade)
  cliente        Cliente?        @relation(fields: [clienteId], references: [id], onDelete: SetNull)
  detallesPedido DetallePedido[]
  pagos          Pago[]

  @@index([usuarioId])
  @@index([clienteId])
  @@map("pedidos")
}

// Modelo DetallePedido
model DetallePedido {
  id              String   @id @default(uuid())
  pedidoId        String
  productoId      String
  cantidad        Int
  precio_unitario Float
  subtotal        Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relaciones
  pedido   Pedido   @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  producto Producto @relation(fields: [productoId], references: [id], onDelete: Restrict)

  @@index([pedidoId])
  @@index([productoId])
  @@map("detalles_pedido")
}

// Modelo Pago
model Pago {
  id                  String   @id @default(uuid())
  pedidoId            String
  usuarioId           String
  monto               Float
  metodo              String // tarjeta, efectivo, transferencia, etc.
  estado              String   @default("pendiente") // pendiente, completado, fallido
  referencia_externa  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  // Relaciones
  pedido  Pedido  @relation(fields: [pedidoId], references: [id], onDelete: Cascade)
  usuario Usuario @relation(fields: [usuarioId], references: [id], onDelete: Cascade)

  @@index([pedidoId])
  @@index([usuarioId])
  @@map("pagos")
}


// Modelo Cupon (para descuentos)
model Cupon {
  id          String   @id @default(uuid())
  codigo      String   @unique
  tipo        String   // "porcentaje" o "monto_fijo"
  valor       Float    // Porcentaje (10 = 10%) o monto fijo ($50)
  activo      Boolean  @default(true)
  usos        Int      @default(0)
  usos_maximos Int?    // null = ilimitado
  monto_minimo Float?  // Monto mínimo de compra requerido
  fecha_inicio DateTime @default(now())
  fecha_fin   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("cupones")
}
